# Port for the backend Express & Socket.io server
PORT=3001

# JSON Web Token secret key for signing authentication tokens
JWT_SECRET=your_jwt_secret_here

# JDoodle Code Execution API Credentials
# Sign up at https://www.jdoodle.com/compiler-api/ to get your keys
JDOODLE_CLIENT_ID=your_jdoodle_client_id_here
JDOODLE_CLIENT_SECRET=your_jdoodle_client_secret_here

# MongoDB Connection String (defaults to local database)
MONGODB_URI=mongodb://127.0.0.1:27017/collab-editor
